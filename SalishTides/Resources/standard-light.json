{
  "version": 8,
  "name": "Salish Standard \u2014 Day",
  "metadata": {
    "comment": "Offline vector basemap. Source tiles are the bundled Protomaps/OSM (ODbL) PMTiles, injected at load time via the {{LOCAL_TILES}} placeholder. Renders with zero network: tiles and the glyph PBFs for the label layers (towns from `places`, island names from `earth` points) are both bundled; `glyphs` resolves through the {{LOCAL_GLYPHS}} placeholder."
  },
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "{{LOCAL_TILES}}"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#cfdce6"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "#cfdce6"
      },
      "filter": [
        "==",
        [
          "geometry-type"
        ],
        "Polygon"
      ]
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {
        "fill-color": "#f4f1ea"
      },
      "filter": [
        "==",
        [
          "geometry-type"
        ],
        "Polygon"
      ]
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "kind"
          ],
          "forest",
          "#e0e8d4",
          [
            "grassland",
            "scrub",
            "wood"
          ],
          "#e6ecdb",
          [
            "glacier",
            "barren"
          ],
          "#eef0ee",
          "#ece9df"
        ],
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse-green",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": [
        "match",
        [
          "get",
          "kind"
        ],
        [
          "park",
          "forest",
          "nature_reserve",
          "grass",
          "recreation_ground",
          "golf_course",
          "cemetery"
        ],
        true,
        false
      ],
      "paint": {
        "fill-color": "#d8e6c6",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "water-inland",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "#cfdce6"
      },
      "filter": [
        "all",
        [
          "==",
          [
            "geometry-type"
          ],
          "Polygon"
        ],
        [
          "!=",
          [
            "get",
            "kind"
          ],
          "ocean"
        ]
      ]
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": [
        "match",
        [
          "get",
          "kind"
        ],
        [
          "country",
          "region"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#9aa7b5",
        "line-dasharray": [
          2,
          2
        ],
        "line-width": 0.8,
        "line-opacity": 0.7
      }
    },
    {
      "id": "island-labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "earth",
      "minzoom": 7,
      "filter": [
        "all",
        [
          "==",
          [
            "geometry-type"
          ],
          "Point"
        ],
        [
          "==",
          [
            "get",
            "kind"
          ],
          "island"
        ]
      ],
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          7,
          10,
          12,
          13
        ],
        "text-letter-spacing": 0.08,
        "text-max-width": 7,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#8d8874",
        "text-halo-color": "#f4f1ea",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 6,
      "filter": [
        "all",
        [
          "==",
          [
            "geometry-type"
          ],
          "Point"
        ],
        [
          "==",
          [
            "get",
            "kind"
          ],
          "locality"
        ],
        [
          "match",
          [
            "get",
            "kind_detail"
          ],
          [
            "city",
            "town",
            "village",
            "hamlet",
            "locality"
          ],
          true,
          false
        ]
      ],
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": [
          "match",
          [
            "get",
            "kind_detail"
          ],
          "city",
          14,
          "town",
          12.5,
          "village",
          11.5,
          10.5
        ],
        "text-max-width": 8,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#3f4640",
        "text-halo-color": "#f7f4ed",
        "text-halo-width": 1.3
      }
    }
  ],
  "glyphs": "{{LOCAL_GLYPHS}}/{fontstack}/{range}.pbf"
}