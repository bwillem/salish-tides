// Base build settings for the SalishTides target.
//
// Secrets (API keys, etc.) must NOT be committed. Put them in the gitignored
// Config/Secrets.xcconfig, which is optionally included below — the build works
// with or without it.
//
// To use the hosted MapTiler Ocean basemap (prototype), create
// Config/Secrets.xcconfig containing:
//
//     MAPTILER_KEY = your_maptiler_api_key
//
// With no key, the app falls back to the bundled offline stub style.

MAPTILER_KEY =

// --- Versioning ---------------------------------------------------------------
// CFBundleShortVersionString / CFBundleVersion reference these (see Info.plist).
// Bump CURRENT_PROJECT_VERSION for every TestFlight upload (must be unique and
// increasing for a given MARKETING_VERSION).
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 2

// --- Code signing -------------------------------------------------------------
// Set DEVELOPMENT_TEAM to your 10-character Apple Developer Team ID for device
// builds and archives (Xcode → Settings → Accounts → team → manage, or
// developer.apple.com → Membership). Simulator builds don't require it.
// Tip: to keep it out of git, instead put `DEVELOPMENT_TEAM = XXXXXXXXXX` in the
// gitignored Config/Secrets.xcconfig, which is included below and overrides this.
DEVELOPMENT_TEAM =
CODE_SIGN_STYLE = Automatic

#include? "Secrets.xcconfig"
