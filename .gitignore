# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
DerivedData/
*.moved-aside
*.xcuserstate

# Swift Package Manager
.build/
.swiftpm/xcode/
.swiftpm/configuration/

# Local secrets (API keys) — never commit
/Config/Secrets.xcconfig

# macOS
.DS_Store
**/.DS_Store

# Data and local dev artifacts
# Anchored to repo root: bare "data/" also matches SalishTides/Data/ on
# case-insensitive filesystems (macOS), which would hide tracked source.
# tides/ + basemap/ ARE committed so Xcode Cloud (no data-bootstrap step) can
# build; everything else under data/ (retired print-atlas maps*/, scratch) stays
# ignored. Regenerated by dev/tides/fetch_tides.py and dev/basemap/.
/data/*
!/data/tides/
!/data/basemap/
/dev/pdfs/
ios-production-handoff/
# Local Claude Code state is ignored, EXCEPT the project's shared skills, which
# are tracked so everyone gets them (e.g. the release-notes skill). Same
# re-include idiom as /data/* above.
.claude/*
!.claude/skills/
__pycache__/
*.pyc

# Pinned per-worktree Xcode DerivedData (parallel agents / sims)
.ddata/
# Local build output (xcodebuild -derivedDataPath)
/build/

# App Store screenshots: generated from the simulator and uploaded to App Store
# Connect, not shipped in the app. Kept on disk under dev/brand/screenshots/.
/dev/brand/screenshots/

# B1 model: large derived artifacts. The reproducible pipeline (b1_download_full
# → b1_analyze_full) is tracked; its bulky outputs are not. b1_grid_full.parts/
# is the resumable per-tile utide cache; b1_grid_full.json is the fat unpacked
# grid. The compact packed grid that actually ships is tracked separately.
/dev/model/b1_grid_full.parts/
/dev/model/b1_grid_full.json
/dev/model/webtide/
